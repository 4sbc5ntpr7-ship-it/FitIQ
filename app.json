{
  "expo": {
    "name": "FitIQ",
    "slug": "fitiq",
    "version": "1.0.0",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.fitiq.app",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a1a"
      },
      "package": "com.fitiq.app",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "fitiq",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a1a"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow FitIQ to access your camera to capture food photos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow FitIQ to access your photos for food recognition."
        }
      ]
    ]
  }
}
